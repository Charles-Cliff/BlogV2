---
import WidgetLayout from './WidgetLayout.astro'
import StatsOverview from './StatsOverview.astro'
import StatsYearlyChart from './StatsYearlyChart.astro'
import StatsUnityPosts from './StatsUnityPosts.astro'
import StatsUnrealPosts from './StatsUnrealPosts.astro'

interface Props {
  totalPosts: number
  totalWords: number
  totalMinutes: number
  avgWords: number
  postsByYear: { year: number; count: number }[]
  unityPosts: { title: string; slug: string; published: Date }[]
  unrealPosts: { title: string; slug: string; published: Date }[]
  class?: string
}

const { totalPosts, totalWords, totalMinutes, avgWords, postsByYear, unityPosts, unrealPosts } = Astro.props
const className = Astro.props.class
---
<div class:list={[className, "w-full flex flex-col gap-4"]}>
  <WidgetLayout name="写作概览" id="stats-overview" class="bg-[var(--card-bg)]">
    <StatsOverview totalPosts={totalPosts} totalWords={totalWords} totalMinutes={totalMinutes} avgWords={avgWords} />
  </WidgetLayout>
  <WidgetLayout name="年度发文" id="stats-yearly" class="bg-[var(--card-bg)]">
    <StatsYearlyChart postsByYear={postsByYear} />
  </WidgetLayout>
  <WidgetLayout name="Unreal相关" id="stats-unreal" class="bg-[var(--card-bg)]">
    <StatsUnrealPosts unrealPosts={unrealPosts} />
  </WidgetLayout>
  <WidgetLayout name="Unity相关" id="stats-unity" class="bg-[var(--card-bg)]">
    <StatsUnityPosts unityPosts={unityPosts} />
  </WidgetLayout>
</div>
